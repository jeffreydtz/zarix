@startuml D-ROB-DASH-003 — Diagrama de Robustez: Visualizar Dashboard
title ZARIX — Diagrama de Robustez - Visualizar Dashboard (CU-003)

skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam linetype ortho
skinparam backgroundColor white
skinparam handwritten false
' ══ Identidad visual Zarix — paleta esmeralda (DESIGN.md) sobre convención de cátedra ══
skinparam roundCorner 10
skinparam TitleFontColor #065F46
skinparam TitleFontSize 15
skinparam TitleFontStyle bold
skinparam ArrowColor #334155
skinparam ArrowFontColor #475569
skinparam ArrowThickness 1.2
skinparam actor {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam usecase {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #334155
}
skinparam boundary {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A8A
}
skinparam control {
  BackgroundColor #FEF9C3
  BorderColor #CA8A04
  FontColor #713F12
}
skinparam entity {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam class {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  HeaderBackgroundColor #DCFCE7
  FontColor #052E16
  AttributeFontColor #334155
  StereotypeFontColor #16A34A
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #16A34A
  FontColor #064E3B
  FontStyle bold
}
skinparam node {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam database {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam component {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam cloud {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A8A
}
skinparam participant {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam sequence {
  LifeLineBorderColor #94A3B8
  LifeLineBackgroundColor #F0FDF4
  GroupBackgroundColor #DCFCE7
  GroupBorderColor #16A34A
  GroupFontColor #064E3B
}
skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #EAB308
  FontColor #713F12
}
skinparam legend {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #064E3B
}


actor "Usuario" as U

boundary "Pantalla Dashboard" as B_Dash
boundary "Widget Patrimonio" as W_Pat
boundary "Widget Cotizaciones" as W_Cot
boundary "Widget Últimos\nMovimientos" as W_Mov
boundary "APIs Externas\n(CriptoYa / DolarApi)" as B_Ext

control "Controlador Dashboard\n(page server component)" as C_Ctrl
control "Gestor de Cotizaciones\n(cotizacionesService)" as C_Cot
control "Calculador de Patrimonio\n(aggregateAccountTotals)" as C_Pat
control "Gestor de Inversiones\n(investmentsService.getPortfolioSummary)" as C_Inv
control "Gestor de Caché\n(in-memory TTL 300s)" as C_Cache

entity "accounts" as E_Cta
entity "investments" as E_Inv
entity "transactions" as E_Mov
entity "exchange_rates" as E_Rate

U --> B_Dash : 1. Abre el dashboard
B_Dash --> C_Ctrl : 2. Solicita datos consolidados
C_Ctrl --> C_Cot : 3. Pide cotizaciones del dólar
C_Cot --> C_Cache : 4. Busca en caché

alt Caché válido (< 300s)
    C_Cache --> C_Cot : 5a. Retorna cotización cacheada
else Caché vencido o vacío
    C_Cot --> B_Ext : 5b. Consulta API de dólar
    B_Ext --> C_Cot : 6b. Retorna cotizaciones
    C_Cot --> E_Rate : 7b. Escribe en exchange_rates
end

C_Ctrl --> C_Pat : 8. Pide agregado de saldos (función pura)
C_Pat --> E_Cta : 9. Lee cuentas (eq user_id)
C_Ctrl --> C_Inv : 10. Pide resumen de portafolio
C_Inv --> E_Inv : 11. Lee posiciones de inversión
C_Pat --> W_Pat : 12. Renderiza patrimonio (USD y ARS)
C_Ctrl --> E_Mov : 13. Lee últimos movimientos
C_Ctrl --> W_Mov : 14. Renderiza últimos 5
C_Cot --> W_Cot : 15. Renderiza cotizaciones (blue/MEP/CCL)

legend right
Proyecto: ZARIX — TIF UAI 2026
Autor: Jeffrey Dietz
Metodología: ICONIX
CU asociado: CU-003 Visualizar Dashboard
Fuente: Ingeniería del código real (Next.js 14 + Supabase)
Boundary (vista/API) | Control (lógica) | Entity (tabla)
Caché en memoria evita golpear las APIs externas en cada carga
endlegend

@enduml

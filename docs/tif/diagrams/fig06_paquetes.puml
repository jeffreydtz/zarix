@startuml D-ARQ-PKG-001 — Diagrama de Paquetes de Zarix
title ZARIX — Diagrama de Paquetes (Arquitectura por Capas)

skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam linetype ortho
skinparam backgroundColor white
skinparam handwritten false
' ══ Identidad visual Zarix — paleta esmeralda (DESIGN.md) sobre convención de cátedra ══
skinparam roundCorner 10
skinparam TitleFontColor #065F46
skinparam TitleFontSize 15
skinparam TitleFontStyle bold
skinparam ArrowColor #334155
skinparam ArrowFontColor #475569
skinparam ArrowThickness 1.2
skinparam actor {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam usecase {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #334155
}
skinparam boundary {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A8A
}
skinparam control {
  BackgroundColor #FEF9C3
  BorderColor #CA8A04
  FontColor #713F12
}
skinparam entity {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam class {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  HeaderBackgroundColor #DCFCE7
  FontColor #052E16
  AttributeFontColor #334155
  StereotypeFontColor #16A34A
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #16A34A
  FontColor #064E3B
  FontStyle bold
}
skinparam node {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam database {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam component {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam cloud {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A8A
}
skinparam participant {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam sequence {
  LifeLineBorderColor #94A3B8
  LifeLineBackgroundColor #F0FDF4
  GroupBackgroundColor #DCFCE7
  GroupBorderColor #16A34A
  GroupFontColor #064E3B
}
skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #EAB308
  FontColor #713F12
}
skinparam legend {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #064E3B
}

skinparam packageStyle rectangle

package "Capa 1: Presentación (UI)" {
    package "app/(authenticated)" as Pages
    package "components/ (por feature + ui/)" as Components
    package "app/page.tsx (landing) · app/shared" as Public
}

package "Capa 2: Routing y Middleware" {
    package "middleware.ts (guard de sesión)" as Middleware
    package "app/api/** (route handlers)" as ApiRoutes
}

package "Capa 3: Servicios (lógica de dominio)" {
    package "transactionsService · accountsService" as SvcCore
    package "cotizacionesService · investmentsService" as SvcMarket
    package "budgets · recurring · sharedExpenses" as SvcOther
}

package "Capa 4: Integración / Infraestructura" {
    package "lib/supabase (server/client)" as SupaClients
    package "lib/ai (Gemini · bot-tools)" as AiLib
    package "lib/telegram (Telegraf bot)" as TgLib
    package "lib/market-data" as MarketLib
}

package "Capa 5: Persistencia" {
    database "Supabase\n(PostgreSQL + Auth + RLS)" as Supabase
}

package "Capa 6: Servicios Externos" {
    node "CriptoYa · DolarApi · CoinGecko" as ApiDolar
    node "Yahoo Finance" as ApiYahoo
    node "Telegram · Gemini · Mercado Pago" as ApiOther
}

Pages --> Components : usa
Pages --> ApiRoutes : fetch
Public --> ApiRoutes : fetch
Middleware --> SupaClients : refresca sesión
ApiRoutes --> SvcCore : invoca
ApiRoutes --> SvcMarket : invoca
ApiRoutes --> SvcOther : invoca
ApiRoutes --> AiLib : chat / anomalías
TgLib --> SvcCore : registra movimientos
TgLib --> AiLib : function-calling
SvcCore --> SupaClients : queries
SvcMarket --> SupaClients : queries
SvcOther --> SupaClients : queries
SvcMarket --> MarketLib : usa
SupaClients --> Supabase : SQL (service-role / RLS)
SvcMarket --> ApiDolar : HTTP
SvcMarket --> ApiYahoo : HTTP
AiLib --> ApiOther : HTTP

legend right
Proyecto: ZARIX — TIF UAI 2026
Autor: Jeffrey Dietz
Metodología: ICONIX
Fuente: Ingeniería del código real (Next.js 14 + Supabase)
Dependencias dirigidas hacia adentro: UI -> Rutas -> Servicios ->
Infraestructura -> Persistencia. Los externos se acceden por la Capa 3/4.
endlegend

@enduml

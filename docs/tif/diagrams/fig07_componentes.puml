@startuml D-ARQ-COMP-001 — Diagrama de Componentes de Zarix
title ZARIX — Diagrama de Componentes

skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam linetype ortho
skinparam backgroundColor white
skinparam handwritten false
' ══ Identidad visual Zarix — paleta esmeralda (DESIGN.md) sobre convención de cátedra ══
skinparam roundCorner 10
skinparam TitleFontColor #065F46
skinparam TitleFontSize 15
skinparam TitleFontStyle bold
skinparam ArrowColor #334155
skinparam ArrowFontColor #475569
skinparam ArrowThickness 1.2
skinparam actor {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam usecase {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #334155
}
skinparam boundary {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A8A
}
skinparam control {
  BackgroundColor #FEF9C3
  BorderColor #CA8A04
  FontColor #713F12
}
skinparam entity {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam class {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  HeaderBackgroundColor #DCFCE7
  FontColor #052E16
  AttributeFontColor #334155
  StereotypeFontColor #16A34A
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #16A34A
  FontColor #064E3B
  FontStyle bold
}
skinparam node {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam database {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam component {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam cloud {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A8A
}
skinparam participant {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam sequence {
  LifeLineBorderColor #94A3B8
  LifeLineBackgroundColor #F0FDF4
  GroupBackgroundColor #DCFCE7
  GroupBorderColor #16A34A
  GroupFontColor #064E3B
}
skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #EAB308
  FontColor #713F12
}
skinparam legend {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #064E3B
}

skinparam componentStyle uml2

package "Vercel (Next.js 14)" {
    component "PWA Frontend\n(React / App Router)" as Front
    component "Route Handlers\n(app/api/**)" as Api
    component "Capa de Servicios\n(lib/services)" as Svc
    component "Bot de Telegram\n(Telegraf)" as Bot
    component "Motor de IA\n(Gemini · function-calling)" as Ai
    component "Cron Jobs\n(7 tareas programadas)" as Cron
}

package "Supabase (BaaS)" {
    database "PostgreSQL\n+ RLS" as Db
    component "Auth (JWT)" as Auth
}

cloud "APIs Externas" {
    component "CriptoYa / DolarApi\n/ CoinGecko" as Dolar
    component "Yahoo Finance" as Yahoo
    component "Telegram Bot API" as TgApi
    component "Mercado Pago" as Mp
}

' ─── Interfaces provistas/requeridas ───
interface "HTTP/REST" as IHttp
interface "supabase-js" as ISupa

Front --> IHttp
IHttp - Api
Api --> Svc : usa
Api --> Ai : chat / anomalías
Bot --> Svc : registra movimientos
Bot --> Ai : interpreta texto / foto (OCR base64)
Cron --> Svc : ejecuta recurrentes / precios
Svc --> ISupa
ISupa - Db
Svc --> Auth : valida sesión
Bot ..> TgApi : webhook + descarga foto
Svc ..> Dolar : cotizaciones
Svc ..> Yahoo : precios de acciones
Api ..> Mp : suscripciones / webhook

legend right
Proyecto: ZARIX — TIF UAI 2026
Autor: Jeffrey Dietz
Metodología: ICONIX
Fuente: Ingeniería del código real (Next.js 14 + Supabase)
Frontend, API, Servicios, Bot, IA y Cron corren en Vercel;
los datos y la auth en Supabase; integraciones vía HTTP.
endlegend

@enduml

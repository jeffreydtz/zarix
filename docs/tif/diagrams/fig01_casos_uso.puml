@startuml D-CU-GEN-001 — Diagrama de Casos de Uso de Zarix
title ZARIX — Casos de Uso Principales (con <<include>> y <<extend>>)

skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam linetype ortho
skinparam backgroundColor white
skinparam handwritten false
' ══ Identidad visual Zarix — paleta esmeralda (DESIGN.md) sobre convención de cátedra ══
skinparam roundCorner 10
skinparam TitleFontColor #065F46
skinparam TitleFontSize 15
skinparam TitleFontStyle bold
skinparam ArrowColor #334155
skinparam ArrowFontColor #475569
skinparam ArrowThickness 1.2
skinparam actor {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam usecase {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #334155
}
skinparam boundary {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A8A
}
skinparam control {
  BackgroundColor #FEF9C3
  BorderColor #CA8A04
  FontColor #713F12
}
skinparam entity {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam class {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  HeaderBackgroundColor #DCFCE7
  FontColor #052E16
  AttributeFontColor #334155
  StereotypeFontColor #16A34A
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #16A34A
  FontColor #064E3B
  FontStyle bold
}
skinparam node {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam database {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam component {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam cloud {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A8A
}
skinparam participant {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam sequence {
  LifeLineBorderColor #94A3B8
  LifeLineBackgroundColor #F0FDF4
  GroupBackgroundColor #DCFCE7
  GroupBorderColor #16A34A
  GroupFontColor #064E3B
}
skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #EAB308
  FontColor #713F12
}
skinparam legend {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #064E3B
}


left to right direction
skinparam actorStyle awesome

' ─── Actores ───
actor "Usuario" as U
actor "Bot de Telegram" as BT
actor "Vercel Cron\n(Programador)" as CRON
actor "Sistema\n(Auth)" as S

' ─── CU principales agrupados por módulo ───
rectangle "Módulo Movimientos" {
    usecase "CU-001\nRegistrar Movimiento" as CU1
}
rectangle "Módulo Cuentas" {
    usecase "CU-002\nGestionar Cuentas" as CU2
}
rectangle "Módulo Dashboard" {
    usecase "CU-003\nVisualizar Dashboard" as CU3
}
rectangle "Módulo Inversiones" {
    usecase "CU-004\nGestionar Portafolio\nde Inversiones" as CU4
}
rectangle "Módulo Datos" {
    usecase "CU-005\nImportar / Exportar\nDatos" as CU5
}
rectangle "Módulo Recurrencia" {
    usecase "CU-006\nGestionar Reglas\nRecurrentes" as CU6
}

' ─── CU incluidos (sub-flujos obligatorios) ───
usecase "CU-AUTH-001\nValidar Sesión\n(getUser)" as CU_AUTH
usecase "CU-001-I1\nActualizar Saldo\nde Cuenta" as CU_SALDO
usecase "CU-001-I2\nValidar Datos\ndel Movimiento" as CU_VAL
usecase "CU-002-I1\nCalcular Saldo\nTotal por Moneda" as CU_TOT
usecase "CU-003-I1\nObtener\nCotizaciones" as CU_COT
usecase "CU-003-I2\nCalcular\nPatrimonio" as CU_PAT
usecase "CU-004-I1\nActualizar Precios\nde Mercado" as CU_PRICE
usecase "CU-004-I2\nCalcular P&L\nde Posición" as CU_PNL
usecase "CU-005-I1\nValidar Formato\nde Archivo" as CU_FMT
usecase "CU-005-I2\nMapear Categorías\ny Cuentas" as CU_MAP
usecase "CU-006-I1\nEjecutar Transacción\nRecurrente" as CU_EXEC

' ─── CU que extienden (sub-flujos opcionales) ───
usecase "CU-001-E1\nRegistrar por\nTelegram" as CU_TG
usecase "CU-001-E2\nParsear Ticket\n(OCR/Gemini)" as CU_OCR
usecase "CU-002-E1\nConfigurar Tarjeta\nBi-Moneda" as CU_BIM
usecase "CU-003-E1\nConsultar\nAsistente IA" as CU_IA
usecase "CU-003-E2\nDetectar\nAnomalías" as CU_ANOM

' ─── Asociaciones actor-CU ───
U --> CU1 : registra
U --> CU2 : administra
U --> CU3 : consulta
U --> CU4 : opera
U --> CU5 : importa/exporta
U --> CU6 : configura
BT --> CU_TG : envía gasto
BT --> CU_OCR : envía foto
S --> CU_AUTH : autentica
CRON --> CU_EXEC : dispara
CRON --> CU_PRICE : refresca

' ─── Includes (sub-flujos obligatorios) ───
CU1 ..> CU_AUTH : <<include>>
CU1 ..> CU_VAL : <<include>>
CU1 ..> CU_SALDO : <<include>>
CU2 ..> CU_AUTH : <<include>>
CU2 ..> CU_TOT : <<include>>
CU3 ..> CU_AUTH : <<include>>
CU3 ..> CU_COT : <<include>>
CU3 ..> CU_PAT : <<include>>
CU4 ..> CU_PRICE : <<include>>
CU4 ..> CU_PNL : <<include>>
CU5 ..> CU_FMT : <<include>>
CU5 ..> CU_MAP : <<include>>
CU6 ..> CU_EXEC : <<include>>

' ─── Extends (sub-flujos opcionales) ───
CU_TG ..> CU1 : <<extend>>
CU_OCR ..> CU1 : <<extend>>
CU_BIM ..> CU2 : <<extend>>
CU_IA ..> CU3 : <<extend>>
CU_ANOM ..> CU3 : <<extend>>

legend right
Proyecto: ZARIX — TIF UAI 2026
Autor: Jeffrey Dietz
Metodología: ICONIX
Fuente: Ingeniería del código real (Next.js 14 + Supabase)
<<include>>: sub-flujo obligatorio | <<extend>>: sub-flujo opcional
Flecha include: CU base → CU incluido | Flecha extend: CU que extiende → CU base
endlegend

@enduml

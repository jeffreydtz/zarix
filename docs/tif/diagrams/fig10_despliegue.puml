@startuml D-ARQ-DEP-001 — Diagrama de Despliegue de Zarix
title ZARIX — Diagrama de Despliegue (Serverless Cloud-Native)

skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam linetype ortho
skinparam backgroundColor white
skinparam handwritten false
' ══ Identidad visual Zarix — paleta esmeralda (DESIGN.md) sobre convención de cátedra ══
skinparam roundCorner 10
skinparam TitleFontColor #065F46
skinparam TitleFontSize 15
skinparam TitleFontStyle bold
skinparam ArrowColor #334155
skinparam ArrowFontColor #475569
skinparam ArrowThickness 1.2
skinparam actor {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam usecase {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #94A3B8
  FontColor #334155
}
skinparam boundary {
  BackgroundColor #DBEAFE
  BorderColor #2563EB
  FontColor #1E3A8A
}
skinparam control {
  BackgroundColor #FEF9C3
  BorderColor #CA8A04
  FontColor #713F12
}
skinparam entity {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam class {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  HeaderBackgroundColor #DCFCE7
  FontColor #052E16
  AttributeFontColor #334155
  StereotypeFontColor #16A34A
}
skinparam package {
  BackgroundColor #F8FAFC
  BorderColor #16A34A
  FontColor #064E3B
  FontStyle bold
}
skinparam node {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam database {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam component {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #052E16
}
skinparam cloud {
  BackgroundColor #EFF6FF
  BorderColor #3B82F6
  FontColor #1E3A8A
}
skinparam participant {
  BackgroundColor #DCFCE7
  BorderColor #16A34A
  FontColor #064E3B
}
skinparam sequence {
  LifeLineBorderColor #94A3B8
  LifeLineBackgroundColor #F0FDF4
  GroupBackgroundColor #DCFCE7
  GroupBorderColor #16A34A
  GroupFontColor #064E3B
}
skinparam note {
  BackgroundColor #FEFCE8
  BorderColor #EAB308
  FontColor #713F12
}
skinparam legend {
  BackgroundColor #F0FDF4
  BorderColor #16A34A
  FontColor #064E3B
}


node "Dispositivo del Usuario" as Device {
    artifact "PWA (navegador)\nReact + Service Worker" as PWA
}

node "Telegram" as Tg {
    artifact "Bot API" as TgBot
}

cloud "Vercel (Edge Network)" as Vercel {
    node "Next.js 14 (Serverless / Fluid)" as Next {
        artifact "Frontend (SSR/CSR)" as FE
        artifact "Route Handlers\n(app/api/**)" as BE
        artifact "Webhook Telegram" as WH
    }
    node "Cron Jobs" as CronNode {
        artifact "recurring · update-prices\nweekly-summary · monthly-summary\nmaturity-alerts · subscription-grace\nbudget-alerts" as CronJobs
    }
}

cloud "Supabase" as Supa {
    database "PostgreSQL\n(+ RLS, triggers)" as PG
    node "Auth (JWT)" as Auth
}

cloud "APIs Externas" as Ext {
    artifact "CriptoYa · DolarApi\nCoinGecko · Yahoo Finance" as Mkt
    artifact "Google Gemini\n(IA / anomalías)" as Gem
}

cloud "Mercado Pago" as MpCloud {
    artifact "Preapproval + Webhook" as MpApi
}

PWA --> FE : HTTPS
PWA ..> BE : fetch / JSON
TgBot --> WH : HTTPS (webhook + secret)
FE --> Auth : JWT
BE --> PG : supabase-js (service-role / RLS)
BE ..> Mkt : HTTPS (cotizaciones)
BE ..> Gem : HTTPS (IA / anomalías)
BE ..> MpApi : suscripciones
MpApi ..> BE : webhook (x-signature HMAC)
CronJobs --> PG : ejecuta tareas
CronJobs ..> Mkt : refresca precios

legend right
Proyecto: ZARIX — TIF UAI 2026
Autor: Jeffrey Dietz
Metodología: ICONIX
Fuente: Ingeniería del código real (vercel.json + código)
Sin servidores propios: cómputo en Vercel (serverless),
datos en Supabase, integraciones por HTTPS. Costo ~ USD 0 en free tier.
endlegend

@enduml
